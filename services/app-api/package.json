{
  "name": "app-api",
  "version": "1.0.0",
  "description": "",
  "license": "CC0-1.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enterprise-CMCS/macpro-mdct-qmr.git"
  },
  "main": "handler.js",
  "scripts": {
    "coverage": "jest --coverage",
    "test": "jest",
    "test-watch": "jest --watch",
    "modify-descriptions": "ts-node ./handlers/dynamoUtils/scripts/modifyDescription.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "~3.1058.0",
    "@aws-sdk/lib-dynamodb": "~3.1058.0",
    "@aws-sdk/util-dynamodb": "~3.996.2",
    "dompurify": "^3.4.9",
    "jsdom": "^28.1.0",
    "jwt-decode": "^3.1.2",
    "kafkajs": "^2.2.4",
    "prompt-sync": "^4.2.0",
    "sanitize-html": "^2.17.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/prompt-sync": "^4.1.1",
    "@types/sanitize-html": "^2.16.0",
    "aws-sdk-client-mock": "~4.1.0",
    "jest": "^30.4.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.8.1",
    "typescript": "^5.9.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "handlers/**/*.{ts,tsx}",
      "libs/**/*.{ts,tsx}",
      "storage/**/*.{ts,tsx}"
    ],
    "coverageReporters": [
      "json",
      [
        "lcov",
        {
          "projectRoot": "../../"
        }
      ],
      "text",
      "text-summary"
    ],
    "globals": {
      "isolatedModules": true
    },
    "moduleDirectories": [
      "node_modules",
      "handlers",
      "libs",
      "util",
      "storage"
    ],
    "setupFilesAfterEnv": [],
    "testTimeout": 33000,
    "transform": {
      "^.+\\.m?js$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                },
                "modules": "commonjs"
              }
            ]
          ]
        }
      ],
      "^.+\\.tsx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@asamuzakjp/|@bramus/|@csstools/|@exodus/bytes/|css-tree/|entities/|lru-cache/|parse5/))"
    ],
    "verbose": true
  }
}
